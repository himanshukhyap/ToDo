rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ────────────────────────────────────────────────────────────
    function isAuth()         { return request.auth != null; }
    function isOwner(userId)  { return request.auth.uid == userId; }

    function validCategory() {
      let d = request.resource.data;
      return d.keys().hasAll(['name','userId','createdAt'])
          && d.name is string && d.name.size() > 0 && d.name.size() <= 100
          && d.userId == request.auth.uid;
    }

    function validTask() {
      let d = request.resource.data;
      return d.keys().hasAll(['title','userId','status','priority','createdAt'])
          && d.title is string && d.title.size() > 0 && d.title.size() <= 120
          && d.status   in ['pending','in-progress','completed']
          && d.priority in ['low','medium','high']
          && d.userId == request.auth.uid;
    }

    // ── categories ─────────────────────────────────────────────────────────
    match /categories/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && validCategory();
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── tasks ───────────────────────────────────────────────────────────────
    match /tasks/{id} {
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && validTask();
      allow update: if isAuth()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
