rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner() {
      return isAuth() && request.auth.uid == resource.data.uid;
    }

    function isCreatingOwn() {
      return isAuth() && request.auth.uid == request.resource.data.uid;
    }

    function isAdminEmail() {
      return isAuth() && request.auth.token.email in [
        "himanshu.kashyap0582@gmail.com",
        "himanshu.khyap@gmail.com"
      ];
    }

    match /notes/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /tasks/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /categories/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /notebooks/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /nb_sections/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /nb_pages/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /nb_trash/{id} {
      allow read:   if isOwner();
      allow create: if isCreatingOwn();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    match /app_settings/{id} {
      allow read: if isAuth();
      allow create, update: if isAdminEmail()
        && request.resource.data.sessionTimeoutMinutes is number
        && request.resource.data.sessionTimeoutMinutes >= 1
        && request.resource.data.sessionTimeoutMinutes <= 240;
      allow delete: if false;
    }
  }
}
